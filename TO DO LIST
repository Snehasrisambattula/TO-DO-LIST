tasks = []

while True:
    print("\n1 Add Task")
    print("2 View Tasks")
    print("3 Delete Task")
    print("4 Exit")

    choice = int(input("Enter your choice: "))
    if choice == 1:
        task = input("Enter task: ")
        tasks.append(task)

    elif choice == 2:
        for t in tasks:
            print(t)

    elif choice == 3:
        task = input("Enter task to delete: ")
        tasks.remove(task)

    elif choice == 4:
        print("Program ended")
        break